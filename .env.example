# Whisper Local - Variables de Entorno
# Copiar este archivo a .env y configurar los valores reales

# ============================================================================
# CONFIGURACIÓN DEL SERVIDOR WHISPER
# ============================================================================

# Host del servidor whisper (default: localhost)
WHISPER_HOST=localhost

# Puerto del servidor whisper (default: 8080)
WHISPER_PORT=8080

# Timeout para transcripciones en segundos (default: 300)
WHISPER_TIMEOUT=300

# Modelo a utilizar (default: ggml-large-v3-turbo)
WHISPER_MODEL=ggml-large-v3-turbo.bin

# ============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# ============================================================================

# Ruta al archivo SQLite (default: whisper.db)
DATABASE_PATH=whisper.db

# ============================================================================
# CONFIGURACIÓN DE TELEGRAM BOT
# ============================================================================

# Token del bot de Telegram (obtener de @BotFather)
# Dejar vacío si no se usa Telegram
TELEGRAM_BOT_TOKEN=

# ID del administrador del bot (opcional, para notificaciones)
TELEGRAM_ADMIN_ID=

# ============================================================================
# CONFIGURACIÓN DE DISCORD BOT
# ============================================================================

# Token del bot de Discord (obtener del portal de desarrolladores)
# Dejar vacío si no se usa Discord
DISCORD_BOT_TOKEN=

# ID del canal por defecto (opcional)
DISCORD_DEFAULT_CHANNEL_ID=

# ============================================================================
# CONFIGURACIÓN DE RATE LIMITING
# ============================================================================

# Límite de archivos por usuario por hora (default: 5)
RATE_LIMIT_PER_USER=5

# Límite global de procesos simultáneos (default: 10)
RATE_LIMIT_GLOBAL=10

# ============================================================================
# CONFIGURACIÓN DE PROCESAMIENTO
# ============================================================================

# Tamaño máximo de archivo en MB antes de hacer chunking (default: 40)
MAX_FILE_SIZE_MB=40

# Duración de cada chunk en segundos (default: 600 = 10 min)
CHUNK_DURATION_SECONDS=600

# Overlap entre chunks en segundos (default: 2)
CHUNK_OVERLAP_SECONDS=2

# Tiempo máximo de lock en minutos (default: 30)
LOCK_TIMEOUT_MINUTES=30

# ============================================================================
# CONFIGURACIÓN DE DIRECTORIOS
# ============================================================================

# Ruta base para archivos de entrada (default: inputs)
INPUTS_BASE_PATH=inputs

# Ruta para transcripciones (default: transcriptions)
TRANSCRIPTIONS_PATH=transcriptions

# Ruta para logs (default: inputs/logs)
LOGS_PATH=inputs/logs

# ============================================================================
# CONFIGURACIÓN DE NOTIFICACIONES
# ============================================================================

# Intervalo de notificación de progreso en porcentaje (default: 10)
PROGRESS_NOTIFICATION_INTERVAL=10

# ============================================================================
# CONFIGURACIÓN DE MÉTRICAS
# ============================================================================

# Habilitar recolección de métricas (default: true)
ENABLE_METRICS=true

# Días de retención de métricas (default: 30)
METRICS_RETENTION_DAYS=30
